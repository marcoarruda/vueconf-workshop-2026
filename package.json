{
    "name": "vueconf-workshop-2026",
    "type": "module",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prettier:check": "prettier \"**/*.{js,ts,vue}\" --check",
        "prettier:write": "prettier \"**/*.{js,ts,vue}\" --write",
        "format": "pnpm run lint:fix && pnpm run prettier:write",
        "db:migrate": "kysely migrate:latest",
        "db:seed": "kysely seed:run",
        "db:rollback": "kysely migrate:rollback --all",
        "db:reset": "pnpm run db:rollback && kysely migrate:latest && kysely seed:run"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1048.0",
        "@aws-sdk/s3-request-presigner": "^3.1048.0",
        "@google/genai": "^2.3.0",
        "@nuxt/eslint": "1.15.2",
        "@primeuix/themes": "^2.0.3",
        "@tailwindcss/vite": "^4.3.0",
        "@vueuse/core": "^14.3.0",
        "dayjs": "^1.11.20",
        "kysely": "^0.29.2",
        "nuxt": "^4.4.5",
        "pg": "^8.20.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "tailwindcss": "^4.3.0",
        "tailwindcss-primeui": "^0.6.1",
        "vasta-orm": "^0.0.13",
        "vue": "^3.5.34",
        "vue-router": "^5.0.7",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@primevue/nuxt-module": "^4.5.5",
        "@types/node": "^24.12.4",
        "@types/pg": "^8.20.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "kysely-ctl": "^0.21.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "typescript": "^6.0.3"
    },
    "packageManager": "pnpm@11.1.2"
}
